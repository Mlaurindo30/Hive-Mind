# Sinapse Agent — Environment Variables
# Copy this file to .env and configure the variables.
# .env is NOT committed (it is in .gitignore).

# ── Gemini API (Google) ─────────────────────────────────────────────────
# Used by Graphify for semantic extraction of the knowledge graph.
# Without this key, Graphify falls back to AST-only (tree-sitter) or local Ollama.
# Get it at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# ── Ollama (optional) ───────────────────────────────────────────────────
# Recommended models for local semantic extraction:
#   ollama pull qwen2.5-coder:3b    # Semantic extraction (1.9GB)
#   ollama pull snowflake-arctic-embed2               # Embeddings (1.2GB)
#   ollama pull minicpm-v4.6:latest   # Compact local vision (default)
#   ollama pull gemma3:4b             # Vision/visual reasoning fallback (local-full)
#   ollama pull deepseek-ocr:latest   # Optional dedicated OCR
# Note: minicpm-v4.6 requires Ollama >= 0.30. On older versions, use gemma3:4b
# as HIVE_VISION_MODEL until you upgrade the Ollama daemon.
#   ollama pull nomic-embed-text     # Lightweight embeddings (0.3GB)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder:3b

# ── LLM per role (role-based) ───────────────────────────────────────────────
# Roles: DREAMER (base), GRAPHIFY, VISION, SYNTHESIS.
# Inheritance: a role without its own PROVIDER+MODEL inherits from the Dreamer (and also the
# Dreamer's fallback). A role with its own primary uses only its own fallback.
# API keys live only in the provider vars (GOOGLE_API_KEY etc.) — never per role.
HIVE_DREAMER_PROVIDER=
HIVE_DREAMER_MODEL=
HIVE_DREAMER_FALLBACK_PROVIDER=
HIVE_DREAMER_FALLBACK_MODEL=
HIVE_GRAPHIFY_PROVIDER=
HIVE_GRAPHIFY_MODEL=
HIVE_GRAPHIFY_FALLBACK_PROVIDER=
HIVE_GRAPHIFY_FALLBACK_MODEL=
HIVE_VISION_PROVIDER=ollama
HIVE_VISION_MODEL=minicpm-v4.6:latest
HIVE_VISION_FALLBACK_PROVIDER=ollama
HIVE_VISION_FALLBACK_MODEL=gemma3:4b
# Optional dedicated OCR. The current pipeline uses HIVE_VISION_* for visual analysis;
# these values are reserved for OCR/document stages that need a specialized model.
HIVE_OCR_PROVIDER=ollama
HIVE_OCR_MODEL=deepseek-ocr:latest
HIVE_SYNTHESIS_PROVIDER=
HIVE_SYNTHESIS_MODEL=
HIVE_SYNTHESIS_FALLBACK_PROVIDER=
HIVE_SYNTHESIS_FALLBACK_MODEL=
# Note: the default EMBEDDING runs locally via Ollama
# (snowflake-arctic-embed2:latest, 1024d). It can be overridden via env for
# debug/migration, but all canonical indexes use 1024 dimensions.
EMBED_BACKEND=ollama
OLLAMA_EMBED_MODEL=snowflake-arctic-embed2:latest

# ── Vectors / Milvus (local K2 production) ─────────────────────────────────────
# sqlite-vec remains the local-first path; Milvus is the production backend for
# distributed vector search and sync-lag verification.
VECTOR_BACKEND=milvus
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION_PREFIX=hm_
HIVE_KNOWLEDGE_HEALTH_MILVUS=1
# Local/fail-open lexical rerank in the RetrievalRouter (K7). Off by default to keep
# local-min lightweight; enable with 1/true/on to reorder candidates by textual
# overlap after the search.
HIVE_RETRIEVAL_RERANKER=0
# Optional local cross-encoder for strong rerank. Requires:
#   uv sync --extra reranker
# Small model recommended to start:
#   cross-encoder/ms-marco-MiniLM-L-6-v2
# HIVE_RERANKER_PROVIDER=sentence-transformers
# HIVE_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RAGFLOW_BASE=http://localhost:9380
RAGFLOW_API_KEY=

# ── CR-SQLite (optional vendor — multi-device sync via CRDT) ─────────────────
# Enables CRDT sync of hive_mind.db across multiple instances.
# Opt-in: default false (zero overhead). Requires install.sh to have downloaded the
# binary in integrations/crsqlite/ (step 13 of install.sh, or
# INSTALL_CRSQLITE=true bash install.sh).
# The hive_mind.db schema must be CRR-compatible (PK NOT NULL DEFAULT)
# - see scripts/setup/setup_crdt.py and core/umc_schema_crr.sql.
HIVE_CRDT_SYNC=false
HIVE_CRSQLITE_VERSION=0.16.3

# ── Langfuse / OpenTelemetry (opt-in observability) ─────────────────────────
# Distributed tracing for the Hive-Mind scripts (Dream Cycle, capture_core,
# sinapse-mcp). Opt-in: comment out (leave empty) to disable — zero
# overhead when no key is set. With keys set, OTLP/HTTP exports are
# sent to Langfuse or any OTel-compatible collector.
# Start local Langfuse: docker compose -f docker-compose.langfuse.yml up -d
# UI at http://localhost:3100 (create a project + copy keys in Settings).
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://localhost:3100
# HIVE_SERVICE_NAME=hive-mind  # used as service.name in OTEL spans
# To activate telemetry: uncomment the 3 variables above (PUBLIC_KEY +
# SECRET_KEY required; HOST optional, default localhost:3100). The
# init_telemetry() in core/telemetry.py detects LANGFUSE_PUBLIC_KEY and
# loads OTEL + HTTP exporter. If the opentelemetry-sdk lib is not
# installed, it emits a warn-once to stderr and continues without telemetry.
# See: docs/13-slo-and-observability.md §3 (L1/L2/E1/D1 - latency and
# tracing).
